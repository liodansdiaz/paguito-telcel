# ──────────────────────────────────────────────────────────────────────────────
# Variables de entorno del FRONTEND (Vite)
# Copia este archivo como .env y ajusta los valores para tu entorno.
# NUNCA commitees el archivo .env con valores reales.
# ──────────────────────────────────────────────────────────────────────────────

# URL base del servidor backend.
# - Desarrollo: dejar en blanco o usar http://localhost:3000
#   (el proxy de Vite redirige /api → backend automáticamente)
# - Producción: cambiar al dominio real de tu API, ej:
#   VITE_BACKEND_URL=https://api.tudominio.com
VITE_BACKEND_URL=http://localhost:3000
