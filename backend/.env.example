EMAIL_FROM="Paguito Telcel <tu_correo@gmail.com>"

# Notificaciones
NOTIFICATIONS_EMAIL=true
NOTIFICATIONS_WHATSAPP=false
NOTIFICATIONS_INTERNAL=true

# Groq AI (chat del sitio)
