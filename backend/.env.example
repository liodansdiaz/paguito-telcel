# ============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - Paguito Telcel
# ============================================================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo como .env en la misma carpeta
# 2. Ejecuta: npm run generate-secrets
# 3. Copia los secrets generados en las variables JWT_SECRET y JWT_REFRESH_SECRET
# 4. Completa el resto de variables según tu entorno
# 5. NUNCA subas el archivo .env a Git
#
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────────────────────────────────────
# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL="postgresql://paguito:paguito123@localhost:5433/paguito_telcel"

# ─────────────────────────────────────────────────────────────────────────────
# JWT - AUTENTICACIÓN (⚠️ CRÍTICO)
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANTE: Ejecuta "npm run generate-secrets" para generar valores seguros
# 
# En producción:
# - Deben tener al menos 64 caracteres
# - Deben ser diferentes entre desarrollo y producción
# - NUNCA usar los valores de ejemplo a continuación
#
# DESARROLLO: Puedes usar estos temporales (⚠️ cambiar en producción)
JWT_SECRET="EJECUTA_npm_run_generate-secrets_PARA_GENERAR_ESTE_VALOR"
JWT_REFRESH_SECRET="EJECUTA_npm_run_generate-secrets_PARA_GENERAR_ESTE_VALOR"

# Tiempo de expiración de tokens
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000

# NODE_ENV: "development" | "production" | "test"
NODE_ENV=development

# URL del frontend (para CORS)
# Desarrollo: http://localhost:5173
# Producción: https://tu-dominio.com
FRONTEND_URL="http://localhost:5173"

# Token secreto para health check detallado (solo producción)
# Ejecuta: npm run generate-secrets (incluye este token)
HEALTH_CHECK_TOKEN=""

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL - NOTIFICACIONES (Nodemailer + Gmail)
# ─────────────────────────────────────────────────────────────────────────────
# Para usar Gmail:
# 1. Activa verificación en 2 pasos en tu cuenta de Google
# 2. Ve a: https://myaccount.google.com/apppasswords
# 3. Genera una contraseña de aplicación
# 4. Usa esa contraseña en SMTP_PASS

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu_correo@gmail.com"
SMTP_PASS="tu_app_password_de_16_caracteres"
EMAIL_FROM="Paguito Telcel <tu_correo@gmail.com>"

# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICACIONES - CANALES
# ─────────────────────────────────────────────────────────────────────────────
# Habilitar/deshabilitar canales de notificación
NOTIFICATIONS_EMAIL=false
NOTIFICATIONS_WHATSAPP=false
NOTIFICATIONS_INTERNAL=true

# ─────────────────────────────────────────────────────────────────────────────
# WHATSAPP - EVOLUTION API
# ─────────────────────────────────────────────────────────────────────────────
# Configuración para envío de notificaciones por WhatsApp via Evolution API
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="tu_api_key_aqui"
EVOLUTION_INSTANCE_NAME="nombre_de_tu_instancia"

# ─────────────────────────────────────────────────────────────────────────────
# GROQ AI - CHAT DEL SITIO (OPCIONAL)
# ─────────────────────────────────────────────────────────────────────────────
# Obtén tu API key gratis en: https://console.groq.com/keys
# Si no se configura, el chat estará deshabilitado
GROQ_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# REDIS - CACHÉ (OPCIONAL)
# ─────────────────────────────────────────────────────────────────────────────
# Redis mejora el rendimiento pero no es obligatorio
REDIS_ENABLED=true
REDIS_HOST="localhost"
REDIS_PORT=6379

# ⚠️ PRODUCCIÓN: Redis DEBE tener contraseña
# DESARROLLO: Puede estar vacío
# Ejecuta: npm run generate-secrets (incluye password de Redis)
REDIS_PASSWORD=""

# ─────────────────────────────────────────────────────────────────────────────
# ALMACENAMIENTO EN LA NUBE (PRODUCCIÓN)
# ─────────────────────────────────────────────────────────────────────────────
# Cloudinary (recomendado para imágenes de productos)
# Regístrate en: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# O usa AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="paguito-telcel-uploads"

# ============================================================================
# NOTAS FINALES
# ============================================================================
# 
# ✅ DESPUÉS DE CONFIGURAR:
# 1. Ejecuta: npm run env:validate
# 2. Si todo está bien, ejecuta: npm run dev
#
# ⚠️ ANTES DE PRODUCCIÓN:
# 1. Cambia NODE_ENV a "production"
# 2. Genera nuevos secrets: npm run generate-secrets
# 3. Configura HTTPS en FRONTEND_URL
# 4. Configura Redis con contraseña
# 5. Configura almacenamiento en la nube (Cloudinary/S3)
# 6. Ejecuta: npm run env:validate
#
# ============================================================================
