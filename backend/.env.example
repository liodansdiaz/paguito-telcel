# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/paguito_telcel"

# JWT
JWT_SECRET="tu_jwt_secret_muy_seguro_aqui"
JWT_REFRESH_SECRET="tu_jwt_refresh_secret_muy_seguro_aqui"
