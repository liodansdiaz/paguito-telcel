generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  VENDEDOR
}

enum EstadoCliente {
  ACTIVO
  BLOQUEADO
}

enum EstadoReserva {
  NUEVA
  ASIGNADA
  EN_VISITA
  PARCIAL
  COMPLETADA
  CANCELADA
  SIN_STOCK
}

enum EstadoReservaItem {
  PENDIENTE
  EN_PROCESO
  VENDIDO
  NO_CONCRETADO
  CANCELADO
  SIN_STOCK
}

enum TipoPago {
  CONTADO
  CREDITO
}

enum CanalNotificacion {
  EMAIL
  WHATSAPP
  INTERNAL
}

enum EstadoNotificacion {
  PENDING
  SENT
  FAILED
}

enum EstrategiaAsignacion {
  ROUND_ROBIN
  MANUAL
}

model User {
  id              String    @id @default(uuid())
  nombre          String
  email           String    @unique
  password        String
  rol             Rol       @default(VENDEDOR)
  isActive        Boolean   @default(true)
  zona            String?
  telefono        String?
  lastAssignedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reservations       Reservation[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  configuracionesAsignacion ConfiguracionAsignacion[]
  asignacionesManuales Reservation[] @relation("AsignacionManual")

  @@map("users")
  @@index([isActive, rol, lastAssignedAt, createdAt])
  @@index([isActive, rol])
}

model Product {
  id              String    @id @default(uuid())
  sku             String    @unique
  nombre          String
  marca           String
  descripcion     String?
  precio          Decimal   @db.Decimal(10, 2)
  precioAnterior  Decimal?  @db.Decimal(10, 2)
  stock           Int       @default(0)
  stockMinimo     Int       @default(5)
  isActive        Boolean   @default(true)
  imagenes        String[]  @default([])
  imagenesColores String[]  @default([])  // Mapeo: qué color corresponde a cada imagen
  colores         String[]  @default([])
  memorias        String[]  @default([])
  badge           String?
  disponibleCredito Boolean @default(true)
  pagosSemanales  String?   // Deprecated: mantener para compatibilidad
  enganche        String?   // Ej: "Desde $300 a $800" o "Desde $350"
  pagoSemanal     String?   // Ej: "Desde $150 a $240" o "$120/semana"
  especificaciones Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reservationItems ReservationItem[]

  @@map("products")
  @@index([isActive, marca, createdAt])
  @@index([isActive, createdAt])
}

model Customer {
  id              String        @id @default(uuid())
  nombreCompleto  String
  telefono        String
  curp            String?       @unique
  email           String?
  direccion       String?
  estado          EstadoCliente @default(ACTIVO)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  reservations    Reservation[]

  @@map("customers")
  @@index([estado, createdAt])
  @@index([nombreCompleto])
  @@index([telefono])
  @@index([email])
}

model Reservation {
  id              String        @id @default(uuid())
  customerId      String
  vendorId        String?

  nombreCompleto  String
  telefono        String
  curp            String?
  direccion       String
  fechaPreferida  DateTime
  horarioPreferido String
  latitude        Decimal?      @db.Decimal(10, 8)
  longitude       Decimal?      @db.Decimal(11, 8)

  estado          EstadoReserva @default(NUEVA)
  estadoDetalle   Json?
  notas           String?
  motivoAsignacion String?
  asignadoManualmentePor String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer        Customer      @relation(fields: [customerId], references: [id])
  vendor          User?         @relation(fields: [vendorId], references: [id])
  asignadoManualmentePorUser User? @relation("AsignacionManual", fields: [asignadoManualmentePor], references: [id])
  items           ReservationItem[]
  notifications   Notification[]

  @@map("reservations")
  @@index([vendorId, estado, createdAt])
  @@index([curp, estado])
  @@index([estado, createdAt])
  @@index([vendorId, fechaPreferida])
  @@index([nombreCompleto])
  @@index([telefono])
  @@index([createdAt])
}

model ReservationItem {
  id            String        @id @default(uuid())
  reservationId String
  productId     String

  color         String?
  memoria       String?
  tipoPago      TipoPago      @default(CONTADO)
  estado        EstadoReservaItem @default(PENDIENTE)
  precioCapturado Decimal      @db.Decimal(10, 2)

  notas         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("reservation_items")
  @@index([reservationId])
  @@index([productId])
  @@index([tipoPago, estado])
  @@index([reservationId, estado])
}

model Notification {
  id                  String              @id @default(uuid())
  reservationId       String
  canal               CanalNotificacion
  status              EstadoNotificacion  @default(PENDING)
  destinatario        String?             // Email o teléfono
  destinatarioNombre  String?             // Nombre del destinatario
  asunto              String?             // Asunto (solo emails)
  mensaje             String?
  error               String?
  sentAt              DateTime?
  createdAt           DateTime            @default(now())

  reservation         Reservation         @relation(fields: [reservationId], references: [id])

  @@map("notifications")
  @@index([reservationId, status])
  @@index([canal, status])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([userId, expiresAt])
  @@index([userId, revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
  @@index([userId, expiresAt])
}

// RoundRobinState eliminado — el algoritmo de asignación round-robin
// se implementa directamente con el campo lastAssignedAt del modelo User,
// por lo que esta tabla era redundante y nunca se usaba en el código.

model SystemConfig {
  id            String    @id @default(uuid())
  clave         String    @unique
  valor         String
  actualizadoPor String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("system_config")
  @@index([clave])
}

model ChatPromptSection {
  id        Int      @id @default(autoincrement())
  section   String   @unique // "general", "credito", "garantia", "formas_pago", "instrucciones"
  title     String   // "INFORMACIÓN GENERAL", "CRÉDITO — CÓMO FUNCIONA"
  content   String   @db.Text
  order     Int      // Orden de aparición en el prompt
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_prompt_sections")
  @@index([isActive, order])
  @@index([section])
}

model ConfiguracionAsignacion {
  id              Int                   @id @default(autoincrement())
  estrategia      EstrategiaAsignacion  @default(ROUND_ROBIN)
  actualizadoEn   DateTime              @updatedAt
  actualizadoPor  String?
  createdAt       DateTime              @default(now())

  actualizadoPorUser User? @relation(fields: [actualizadoPor], references: [id])

  @@map("configuracion_asignacion")
}
