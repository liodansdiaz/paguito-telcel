generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  VENDEDOR
}

enum EstadoCliente {
  ACTIVO
  BLOQUEADO
}

enum EstadoReserva {
  NUEVA
  ASIGNADA
  EN_VISITA
  VENDIDA
  NO_CONCRETADA
  CANCELADA
  SIN_STOCK
}

enum TipoPago {
  CONTADO
  CREDITO
}

enum CanalNotificacion {
  EMAIL
  WHATSAPP
  INTERNAL
}

enum EstadoNotificacion {
  PENDING
  SENT
  FAILED
}

model User {
  id              String    @id @default(uuid())
  nombre          String
  email           String    @unique
  password        String
  rol             Rol       @default(VENDEDOR)
  isActive        Boolean   @default(true)
  zona            String?
  telefono        String?
  lastAssignedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reservations       Reservation[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
  @@index([isActive, rol, lastAssignedAt, createdAt])
  @@index([isActive, rol])
}

model Product {
  id              String    @id @default(uuid())
  sku             String    @unique
  nombre          String
  marca           String
  descripcion     String?
  precio          Decimal   @db.Decimal(10, 2)
  precioAnterior  Decimal?  @db.Decimal(10, 2)
  stock           Int       @default(0)
  stockMinimo     Int       @default(5)
  isActive        Boolean   @default(true)
  imagenes        String[]  @default([])
  colores         String[]  @default([])
  memorias        String[]  @default([])
  badge           String?
  disponibleCredito Boolean @default(true)
  pagosSemanales  Decimal?  @db.Decimal(10, 2)
  especificaciones Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reservations    Reservation[]

  @@map("products")
  @@index([isActive, marca, createdAt])
  @@index([isActive, createdAt])
}

model Customer {
  id              String        @id @default(uuid())
  nombreCompleto  String
  telefono        String
  curp            String        @unique
  email           String?
  direccion       String?
  estado          EstadoCliente @default(ACTIVO)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  reservations    Reservation[]

  @@map("customers")
  @@index([estado, createdAt])
}

model Reservation {
  id              String        @id @default(uuid())
  customerId      String
  productId       String
  vendorId        String?

  nombreCompleto  String
  telefono        String
  curp            String
  tipoPago        TipoPago      @default(CONTADO)
  direccion       String
  fechaPreferida  DateTime
  horarioPreferido String
  latitude        Decimal?      @db.Decimal(10, 8)
  longitude       Decimal?      @db.Decimal(11, 8)

  estado          EstadoReserva @default(NUEVA)
  notas           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer        Customer      @relation(fields: [customerId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])
  vendor          User?         @relation(fields: [vendorId], references: [id])
  notifications   Notification[]

  @@map("reservations")
  @@index([vendorId, estado, createdAt])
  @@index([curp, tipoPago, estado])
  @@index([curp, estado])
  @@index([estado, createdAt])
  @@index([vendorId, fechaPreferida])
}

model Notification {
  id            String              @id @default(uuid())
  reservationId String
  canal         CanalNotificacion
  status        EstadoNotificacion  @default(PENDING)
  mensaje       String?
  error         String?
  sentAt        DateTime?
  createdAt     DateTime            @default(now())

  reservation   Reservation         @relation(fields: [reservationId], references: [id])

  @@map("notifications")
  @@index([reservationId, status])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([userId, expiresAt])
  @@index([userId, revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
  @@index([userId, expiresAt])
}

// RoundRobinState eliminado — el algoritmo de asignación round-robin
// se implementa directamente con el campo lastAssignedAt del modelo User,
// por lo que esta tabla era redundante y nunca se usaba en el código.
